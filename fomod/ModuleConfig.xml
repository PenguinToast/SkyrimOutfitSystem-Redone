<?xml version="1.0" encoding="UTF-8"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://qconsulting.ca/fo3/ModConfig5.0.xsd">
  <moduleName>Skyrim Outfit System Redone</moduleName>
  <requiredInstallFiles>
    <folder source="Data" destination="" />
  </requiredInstallFiles>
  <installSteps order="Explicit">
    <installStep name="Game Version">
      <optionalFileGroups order="Explicit">
        <group name="Select Runtime" type="SelectExactlyOne">
          <plugins order="Explicit">
            <plugin name="Skyrim SE / Anniversary Edition">
              <description>Installs the shared Skyrim SE / AE plugin build.</description>
              <files>
                <folder source="SkyrimSE" destination="" priority="0" />
              </files>
              <typeDescriptor>
                <type name="Required" />
              </typeDescriptor>
            </plugin>
            <plugin name="Skyrim VR">
              <description>Installs the Skyrim VR-specific plugin build.</description>
              <files>
                <folder source="SkyrimVR" destination="" priority="0" />
              </files>
              <typeDescriptor>
                <type name="Required" />
              </typeDescriptor>
            </plugin>
          </plugins>
        </group>
      </optionalFileGroups>
    </installStep>
  </installSteps>
</config>
